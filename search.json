---
layout: null
---
[
  {% assign notes = site.pages | where_exp: "page", "page.path contains 'notes/'" %}
  {% for page in notes %}
  {
    "title": {{ page.title | jsonify }},
    "url": {{ page.url | jsonify }},
    "content": {{ page.content | strip_html | strip_newlines | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
